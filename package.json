    "express-xss-sanitizer": "^2.0.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
